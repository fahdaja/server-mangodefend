# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# URL koneksi untuk database utama aplikasi postgresql
# Format: protocol://username:password@hostname:port/database_name
DATABASE_URL=postgresql://your_db_user:your_db_password@127.0.0.1:5432/your_db_name

# ==============================================================================
# JWT (JSON WEB TOKEN) CONFIGURATION
# ==============================================================================
# String acak yang digunakan sebagai kunci rahasia untuk enkripsi token JWT internal
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# Durasi masa berlaku token internal (contoh: 1d, 24h, atau angka dalam detik)
JWT_EXPIRES_IN=24h

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================
# URL endpoint API dari proyek Supabase Anda
SUPABASE_URL=https://supabase.co

# Kunci API Supabase (anon key atau service role key tergantung kebutuhan hak akses)
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# Nama folder/bucket penyimpanan file di Supabase Storage
SUPABASE_BUCKET_NAME=your_supabase_bucket_name

# ==============================================================================
# FIREBASE CONFIGURATION
# ==============================================================================
# ID unik dari proyek Firebase Anda untuk verifikasi ID Token
FIREBASE_PROJECT_ID=your-firebase-project-id
